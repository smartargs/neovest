# Copy this file to `.env.local` and fill in your values.

# WalletConnect Cloud project ID. Get one at https://cloud.reown.com.
# Without this, the Connect button will be disabled (read-only mode still works).
VITE_WC_PROJECT_ID=

# RPC endpoint. Defaults to mainnet1.neo.coz.io if unset.
# VITE_RPC_URL=https://mainnet1.neo.coz.io:443

# Network the dapp targets. "mainnet" or "testnet".
VITE_NETWORK=mainnet
