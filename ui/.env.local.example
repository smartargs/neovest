# Copy to `.env.local` for development against a local Neo N3 private-net.
# See `docs/LOCAL.md` for the full walkthrough.

# Network the UI is talking to. Affects:
#   - The top-of-page banner: hidden on mainnet, amber on testnet,
#     blue on localnet.
#   - The default RPC URL when VITE_RPC_URL is unset.
# Valid values: mainnet | testnet | localnet
VITE_NETWORK=localnet

# RPC endpoint. Leave UNSET to use the Vite dev-server proxy at /__rpc,
# which forwards to http://localhost:10332 (client1) — the proxy is the
# fix for neo-cli's missing CORS headers.
# Override only if you want to bypass the proxy or hit a different node:
#   - To target client2/consensus, set LOCAL_RPC_PROXY_TARGET in your shell
#     before `npm run dev` (e.g. LOCAL_RPC_PROXY_TARGET=http://localhost:40332).
#   - Or set VITE_RPC_URL=http://localhost:10332 directly (will hit CORS).
# VITE_RPC_URL=

# WalletConnect project ID (https://cloud.reown.com). Leave empty to
# disable WalletConnect; NeoLine direct still works.
VITE_WC_PROJECT_ID=
