{
  "name": "neovest-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync-checksum": "node scripts/sync-checksum.mjs",
    "sync-artifacts": "node scripts/sync-artifacts.mjs",
    "sync": "npm run sync-checksum && npm run sync-artifacts",
    "predev": "npm run sync",
    "prebuild": "npm run sync",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@cityofzion/appkit-neo3-adapter": "^1.0.0",
    "@cityofzion/neon-dappkit": "^1.0.0",
    "@cityofzion/neon-dappkit-types": "^1.0.0",
    "@cityofzion/neon-js": "^5.9.0",
    "@reown/appkit": "^1.8.19",
    "@tanstack/react-query": "^5.100.9",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.59.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-node-polyfills": "^0.26.0"
  }
}
